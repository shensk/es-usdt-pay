# ===========================================
# Webman USDT Payment System 环境配置示例
# ===========================================

# 应用配置
APP_DEBUG=true
APP_ENV=local

# 数据库配置
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=usdt_payment
DB_USERNAME=root
DB_PASSWORD=your_password
DB_CHARSET=utf8mb4

# Redis配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# USDT支付系统配置
USDT_API_KEY=your_api_key_here
USDT_API_SECRET=your_api_secret_here
USDT_CALLBACK_URL=https://your-domain.com/api/callback
USDT_NOTIFY_URL=https://your-domain.com/api/notify

# 订单配置
ORDER_TIMEOUT=1800
MIN_AMOUNT=1
MAX_AMOUNT=50000
ORDER_PREFIX=USDT

# 汇率配置
EXCHANGE_RATE_API=https://api.exchangerate-api.com/v4/latest/USD
EXCHANGE_RATE_CACHE_TIME=300
DEFAULT_CNY_RATE=7.2

# TronScan API配置
TRONSCAN_API_URL=https://apilist.tronscanapi.com
TRONSCAN_TIMEOUT=10
BLOCKCHAIN_MONITOR_INTERVAL=30

# 钱包配置
WALLET_MIN_BALANCE=10
WALLET_CHECK_INTERVAL=300
AUTO_WALLET_ROTATION=true

# 安全配置
SIGNATURE_ALGORITHM=md5
IP_WHITELIST=
REQUEST_TIMEOUT=30
MAX_RETRY_TIMES=3

# 日志配置
LOG_LEVEL=info
LOG_PATH=runtime/logs
LOG_MAX_FILES=30

# 邮件配置（可选）
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="USDT Payment System"

# 短信配置（可选）
SMS_DRIVER=aliyun
SMS_ACCESS_KEY=your_sms_access_key
SMS_ACCESS_SECRET=your_sms_access_secret
SMS_SIGN_NAME=your_sms_sign
SMS_TEMPLATE_CODE=your_template_code

# 监控配置
MONITOR_ENABLED=true
MONITOR_WEBHOOK_URL=
ALERT_EMAIL=admin@your-domain.com
HEALTH_CHECK_INTERVAL=60

# 缓存配置
CACHE_DRIVER=redis
CACHE_PREFIX=usdt_payment
CACHE_TTL=3600

# 队列配置
QUEUE_DRIVER=redis
QUEUE_CONNECTION=default
QUEUE_FAILED_TABLE=failed_jobs

# 文件存储配置
FILESYSTEM_DRIVER=local
UPLOAD_MAX_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx

# API限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_MINUTES=1

# 管理后台配置
ADMIN_PATH=admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_SESSION_LIFETIME=120

# 第三方服务配置
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# 备份配置
BACKUP_ENABLED=false
BACKUP_PATH=storage/backups
BACKUP_RETENTION_DAYS=30

# 性能配置
MAX_MEMORY_LIMIT=256M
MAX_EXECUTION_TIME=300
OPCACHE_ENABLED=true

# 开发环境配置
DEBUGBAR_ENABLED=false
PROFILER_ENABLED=false
QUERY_LOG_ENABLED=false

# ===========================================
# 配置说明：
# 1. 复制此文件为 .env 并修改相应配置
# 2. 数据库和Redis连接信息必须正确配置
# 3. USDT_API_KEY 和 USDT_API_SECRET 用于API签名验证
# 4. USDT_CALLBACK_URL 是支付成功后的回调地址
# 5. 生产环境请将 APP_DEBUG 设置为 false
# 6. 建议定期更换 API 密钥以确保安全
# ===========================================
